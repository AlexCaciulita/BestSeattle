# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ticketmaster Discovery API (affiliate revenue source)
# Get key: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=
TICKETMASTER_AFFILIATE_ID=

# Eventbrite API
# Get key: https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=

# SerpApi — Google Events aggregation (free: 250 queries/month)
# Get key: https://serpapi.com/
SERPAPI_KEY=

# Google Places API (server-side only; used for autocomplete/place details/photo)
GOOGLE_PLACES_API_KEY=

# Google Maps JavaScript API (browser key; restrict by HTTP referrer)
# Use one of these:
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
GOOGLE_MAPS_BROWSER_KEY=
